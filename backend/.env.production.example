# Production server (.env)
# Өндірісте: /opt/ortax/backend/.env

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL) — setup-server.sh /root/ortax/db-credentials.env-ке жазады
DB_ENABLED=true
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ortax
DB_PASSWORD=<<replace-from-/root/ortax/db-credentials.env>>
DB_NAME=ortax

# JWT
JWT_SECRET=<<openssl rand -hex 32>>
JWT_EXPIRES_IN=7d

# SMS provider
SMS_PROVIDER=mock
SMS_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-proj-XXX
OPENAI_MODEL=gpt-4o-mini

# TTS
TTS_MODEL=tts-1
TTS_VOICE=onyx

# Telegram bots
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=<<yassawi-token>>
TELEGRAM_BOT_TOKEN_KHWARIZMI=<<khwarizmi-token>>
